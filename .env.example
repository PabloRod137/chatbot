# ==============================================================================
# ⚠️ ARCHIVO DE CONFIGURACIÓN DE CREDENCIALES ⚠️
# Este archivo contiene claves sensibles. NUNCA lo publiques en repositorios públicos.
# Renombra a .env y completa con tus valores reales.
# ==============================================================================

# ==============================================================================
# CONFIGURACIÓN DE MENSAJERÍA - Elige uno: TELEGRAM o WHATSAPP
# ==============================================================================

# --- OPCIÓN 1: TELEGRAM ---
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# --- OPCIÓN 2: WHATSAPP (Meta) ---
WHATSAPP_ENABLED=true
WHATSAPP_TOKEN=YOUR_WHATSAPP_API_TOKEN_HERE
WHATSAPP_PHONE_ID=YOUR_WHATSAPP_PHONE_ID_HERE
WHATSAPP_BUSINESS_ACCOUNT_ID=YOUR_BUSINESS_ACCOUNT_ID_HERE
VERIFY_TOKEN=YOUR_WEBHOOK_VERIFY_TOKEN_HERE

# ==============================================================================
# CONFIGURACIÓN DE IA Y MODELOS
# ==============================================================================
# API Key de Google AI Studio para usar Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Modelo de Gemini a usar (ej: gemini-1.5-pro-latest, gemini-1.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ==============================================================================
# CONFIGURACIÓN DE APLICACIÓN
# ==============================================================================
# Nombre de tu negocio o aplicación
APP_NAME=""
# Ruta de la base de datos SQLite
DB_PATH=chatbot.db
